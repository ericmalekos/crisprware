# 1. Ignore everything in the repository
*

# Allow
!.gitignore

!MANIFEST.in
!README.md
!environment.yml
!license.txt
!pyproject.toml

# Directories: must un-ignore both the dir and its contents
!.github/
!.github/**
!annotations/
!annotations/**
!colab_notebooks/
!colab_notebooks/**
!crisprware/
!crisprware/**
!dist/
!dist/**
!docker/
!docker/**
!images/
!images/**
!parasol_scripts/
!parasol_scripts/**
!scripts/
!scripts/**
!tests/
!tests/**

# Re-ignore generated/build artifacts (must come after un-ignore rules)
__pycache__/
*.pyc
.ipynb_checkpoints/
*.egg-info/
