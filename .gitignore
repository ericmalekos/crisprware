# 1. Ignore everything in the repository
*

# Allow
!.gitignore

!MANIFEST.in
!README.md
!environment.yml
!license.txt
!pyproject.toml

# Directories: must un-ignore both the dir and its contents
!.github/
!.github/**
!annotations/
!annotations/**
!colab_notebooks/
!colab_notebooks/**
!crispr-ots/
!crispr-ots/**
!crisprware/
!crisprware/**
!conda-recipe/
!conda-recipe/**
!dist/
!dist/**
!docker/
!docker/**
!images/
!images/**
!parasol_scripts/
!parasol_scripts/**
!scripts/
!scripts/**
!tests/
!tests/**
!tools/
!tools/**

# Re-ignore generated/build artifacts (must come after un-ignore rules)
__pycache__/
*.pyc
.ipynb_checkpoints/
*.egg-info/

# Rust workspace artifacts (crispr-ots/)
crispr-ots/target/
crispr-ots/**/*.rs.bk
crispr-ots/**/*.crot
crispr-ots/**/*.profraw
crispr-ots/**/flamegraph.svg
crispr-ots/**/perf.data*
# Out-of-tree GPU build dir + build/test logs and generated test artifacts
crispr-ots/target-gpu/
crispr-ots/gpu_build.log
crispr-ots/dualmat_build.*
tests/test_data/**/*.fai
tests/test_data/**/*.dna
